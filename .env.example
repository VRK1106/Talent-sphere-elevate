# Vector Embedding Model
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Vector Database configuration
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=talent_sphere_docs

# Text Chunking Settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5

# Document storage directory
DOCUMENTS_DIR=./documents

# API Keys
# Get your Groq API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# SMTP configuration for User Credentials and Announcements emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_SENDER=Talent Sphere Elevate <your_gmail_address@gmail.com>
SMTP_USE_TLS=True

# Application Base URL (used for absolute links in emails)
APP_URL=http://localhost:5000
